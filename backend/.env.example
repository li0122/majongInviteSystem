PORT=4000
# Prefer a managed MongoDB URI in production (Atlas or dedicated host).
MONGO_URI=mongodb://localhost:27017/mahjong_match
# Optional alias supported by backend: MONGODB_URI=
JWT_SECRET=please_change_me
OTP_EXPIRE_MINUTES=10
OTP_EMAIL_FROM=no-reply@mahjongmatch.local
SMTP_PROVIDER=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=demo_user
SMTP_PASS=demo_pass
# Optional Gmail shortcuts (recommended with SMTP_PROVIDER=gmail)
GMAIL_USER=
GMAIL_APP_PASSWORD=
FIREBASE_PROJECT_ID=your_project_id
# Base64-encoded firebase service account json
FIREBASE_SERVICE_ACCOUNT_BASE64=
